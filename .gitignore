# ============================================
# DEPENDENCIES
# ============================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ============================================
# ENVIRONMENT VARIABLES - CRITICAL: NEVER COMMIT
# ============================================
.env
.env.*
backend/.env
backend/.env.*
frontend/.env
frontend/.env.*
# Exception: example files ARE committed (no real secrets)
!backend/.env.example
!frontend/.env.example
!backend/.env.teams.example

# ============================================================================
# DEPLOYMENT CONFIGURATION - CRITICAL: NEVER COMMIT PRODUCTION SECRETS
# ============================================================================
# Store deployment configs in Render/Vercel dashboard, not in git
render.yaml
render.*.yaml
docker-compose.yml.local
.vercel/env*.json

# ============================================
# BUILD OUTPUT
# ============================================
dist/
build/
*.tsbuildinfo
frontend/dist/
backend/dist/

# ============================================
# IDE & EDITOR
# ============================================
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
*.sublime-project
*.sublime-workspace

# ============================================
# OS FILES
# ============================================
.DS_Store
Thumbs.db
.env.local.php
.cache/

# ============================================
# LOGS
# ============================================
logs/
*.log
backend/logs/

# ============================================
# UPLOADS & TEMPORARY FILES
# ============================================
uploads/
temp/
tmp/
*.tmp

# ============================================
# DATABASE
# ============================================
*.db
*.sqlite
*.sqlite3

# ============================================
# TESTING
# ============================================
coverage/
.nyc_output/
.mocha_output/

# ============================================
# MISC
# ============================================
.env.example.local
.vercel
.vercel/
render.yaml.local
*.pem
*.key
*.crt
