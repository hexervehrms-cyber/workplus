# ============================================
# WORKPLUS PRO - PRODUCTION ENVIRONMENT
# ============================================

# ============================================
# BACKEND CONFIGURATION
# ============================================

# Server
PORT=5000
NODE_ENV=production

# Database - MongoDB Atlas
MONGODB_URI=mongodb+srv://your_username:your_password@your_cluster.mongodb.net/workpluspro?retryWrites=true&w=majority

# Security - CRITICAL: Change this in production!
JWT_SECRET=your-secure-jwt-secret-key-minimum-32-characters-long-change-this
JWT_EXPIRES_IN=24h

# CORS - Production Frontend (Vercel)
CORS_ORIGIN=https://your-frontend-domain.vercel.app

# ============================================
# SUPER ADMIN CREDENTIALS
# ============================================

SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=your-secure-password-here
SUPER_ADMIN_NAME=Administrator

# ============================================
# NOTIFICATION SERVICES
# ============================================

# Email Configuration (SMTP)
# Microsoft 365 SMTP Configuration
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=noreply@hexerve.com
SMTP_PASS=your-outlook-password
FROM_EMAIL=noreply@hexerve.com
HR_EMAIL=hr2hexerve@gmail.com

# SMS Configuration (Twilio)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Push Notifications (Firebase)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY=your-firebase-private-key
FIREBASE_CLIENT_EMAIL=your-firebase-client-email

# ============================================
# FRONTEND CONFIGURATION
# ============================================

# API Configuration - Production
VITE_API_URL=https://your-backend-domain.com
VITE_SOCKET_URL=https://your-backend-domain.com

# App Configuration
VITE_APP_NAME=WorkPlus Pro
VITE_APP_VERSION=1.0.0
VITE_APP_ENV=production

# Feature Flags
VITE_ENABLE_DEBUG=false
VITE_ENABLE_ANALYTICS=true

# ============================================
# MICROSOFT TEAMS INTEGRATION
# ============================================

# Teams App Configuration (from Azure AD)
TEAMS_APP_ID=your-teams-app-id
TEAMS_APP_PASSWORD=your-teams-app-password
TEAMS_TENANT_ID=your-teams-tenant-id
TEAMS_BOT_ID=your-teams-bot-id
TEAMS_BOT_PASSWORD=your-teams-bot-password

# Teams Webhook URL
TEAMS_WEBHOOK_URL=https://your-backend-domain.com/api/chat/teams/webhook

# Teams Integration Features
TEAMS_INTEGRATION_ENABLED=true
TEAMS_MESSAGE_SYNC_ENABLED=true
TEAMS_PRESENCE_SYNC_ENABLED=true
TEAMS_FILE_SHARING_ENABLED=true

# Teams Message Retention (in days)
TEAMS_MESSAGE_RETENTION_DAYS=90

# Teams Rate Limiting
TEAMS_API_RATE_LIMIT=100
TEAMS_API_RATE_LIMIT_WINDOW=60000

# Teams Logging
TEAMS_LOG_LEVEL=info
TEAMS_LOG_MESSAGES=true
