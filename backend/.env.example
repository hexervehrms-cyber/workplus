# WorkPlus Backend Environment Configuration
# Copy this to .env and fill in actual values for your environment

# ============================================================================
# PRODUCTION / DEPLOYMENT
# ============================================================================

# Environment mode (development or production)
NODE_ENV=production

# Server port
PORT=5000

# ============================================================================
# DATABASE
# ============================================================================

# MongoDB connection string (Atlas or local)
# Format: mongodb+srv://username:password@cluster.mongodb.net/dbname?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/workplus?retryWrites=true&w=majority

# ============================================================================
# JWT & SECURITY
# ============================================================================

# JWT secret for token signing (MUST be secure, minimum 32 characters)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# CRITICAL: Change this value in production!
JWT_SECRET=your-secure-random-jwt-secret-key-minimum-32-characters-long-change-this

# Token expiration times
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# ============================================================================
# CORS & FRONTEND
# ============================================================================

# Frontend URL for CORS (comma-separated for multiple origins)
# Example: https://workplus.example.com,https://app.workplus.com
CORS_ORIGIN=https://workplus.vercel.app

# Frontend URL (used in email links, onboarding)
FRONTEND_URL=https://workplus.vercel.app

# ============================================================================
# SUPER ADMIN SEEDING
# ============================================================================

# Initial super admin credentials (set during first deploy)
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=SecureP@ssw0rd123
SUPER_ADMIN_NAME=Super Administrator

# ============================================================================
# OPTIONAL: Email Service
# ============================================================================

# SMTP configuration (if email notifications needed)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=noreply@workplus.com

# ============================================================================
# OPTIONAL: Redis Cache
# ============================================================================

# Redis URL for session & JWT caching (improves performance)
# REDIS_URL=redis://localhost:6379

# ============================================================================
# OPTIONAL: Third-party Integrations
# ============================================================================

# Slack, Teams, or other integrations go here
# SLACK_WEBHOOK_URL=https://hooks.slack.com/...
# TEAMS_WEBHOOK_URL=https://outlook.webhook.office.com/...

# ============================================================================
# MONITORING & LOGGING
# ============================================================================

# Log level (error, warn, info, debug)
LOG_LEVEL=info

# External monitoring (DataDog, New Relic, etc.)
# DATADOG_API_KEY=...

# ============================================================================
# DATABASE PERFORMANCE TUNING (Optional)
# ============================================================================

# Connection pool sizes (Render/production)
MONGO_MAX_POOL_SIZE=40
MONGO_MIN_POOL_SIZE=2

# ============================================================================
# DEVELOPMENT ONLY (DO NOT USE IN PRODUCTION)
# ============================================================================

# Enable debug endpoints (should be false in production)
# NODE_ENV will automatically block these anyway
DEBUG_ENABLED=false

# Skip email sending in development
# SKIP_EMAIL=true
