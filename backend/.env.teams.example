# Microsoft Teams Integration Configuration
# Copy this file to .env and fill in your Teams credentials

# Teams App Configuration
TEAMS_APP_ID=your_teams_app_id_here
TEAMS_APP_PASSWORD=your_teams_app_password_here
TEAMS_TENANT_ID=your_tenant_id_here
TEAMS_BOT_ID=your_bot_id_here
TEAMS_BOT_PASSWORD=your_bot_password_here

# Teams Webhook URL (for incoming webhooks)
TEAMS_WEBHOOK_URL=https://your-domain.com/api/chat/teams/webhook

# Microsoft Graph API Endpoint
TEAMS_GRAPH_ENDPOINT=https://graph.microsoft.com/v1.0

# Teams Integration Features
TEAMS_INTEGRATION_ENABLED=true
TEAMS_MESSAGE_SYNC_ENABLED=true
TEAMS_PRESENCE_SYNC_ENABLED=true
TEAMS_FILE_SHARING_ENABLED=true

# Teams Message Retention (in days)
TEAMS_MESSAGE_RETENTION_DAYS=90

# Teams Rate Limiting
TEAMS_API_RATE_LIMIT=100
TEAMS_API_RATE_LIMIT_WINDOW=60000

# Teams Logging
TEAMS_LOG_LEVEL=info
TEAMS_LOG_MESSAGES=false
