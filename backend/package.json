    "apn": "^1.6.2",
    "axios": "^1.16.1",
    "bcrypt": "^6.0.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "date-fns": "3.6.0",
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "express-rate-limit": "^8.4.0",
    "express-validator": "^7.3.2",
    "firebase-admin": "^13.10.0",
    "helmet": "^8.1.0",
    "isomorphic-dompurify": "^2.16.0",
