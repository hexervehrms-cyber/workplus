{
  "name": "workplus-backend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "WorkPlus HRMS Backend - Production Ready",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "server": "node server.js",
    "dev": "node server.js",
    "build": "echo 'Backend is ready - no build required'",
    "create-indexes": "node scripts/createIndexes.js",
    "init-rbac": "node scripts/initializeRBAC.js",
    "init-security": "node scripts/initializeSecurity.js",
    "setup": "npm run init-rbac && npm run init-security",
    "test": "vitest run",
    "test:watch": "vitest"
